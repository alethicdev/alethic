# distutils' default sdist glob is `test*.py`, which matches the test modules but
# not conftest.py, helpers.py or __init__.py -- so the sdist shipped a test suite
# that could not run (7 collection errors). Anyone packaging from source and
# running the tests, which is what distro and conda-forge maintainers do, hit it.
recursive-include tests *.py

include LICENSE
include CHANGELOG.md
include CONTRIBUTING.md
include SECURITY.md
include CODE_OF_CONDUCT.md
recursive-include docs *.md *.png
